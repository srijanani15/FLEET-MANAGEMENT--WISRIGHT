# ---------------------------------------------------------------------------
# Telematics Backend — environment variables
# Copy to `.env` for local runs, OR set these in Coolify's "Environment
# Variables" panel for the app resource. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# ---- MySQL connection ----
# Point MYSQL_HOST at your Coolify MySQL service name (internal hostname shown
# in the Coolify database resource). For the FIRST boot, using the root user is
# the least-friction choice because init_db() runs `CREATE DATABASE IF NOT
# EXISTS` + CREATE TABLE, which needs schema privileges.
MYSQL_HOST=telematics-mysql
MYSQL_USER=root
MYSQL_PASSWORD=change-me-strong-mysql-root-password
MYSQL_DATABASE=telematics

# ---- Device authentication ----
# Must EXACTLY match `#define DEVICE_TOKEN` in BusTracking/.../bus_final.ino
DEVICE_TOKEN=change-me-to-a-long-random-token

# ---- ngrok ----
# Leave EMPTY on a real VPS. The public domain (Coolify/Traefik + Let's Encrypt)
# replaces the ngrok tunnel entirely.
NGROK_AUTHTOKEN=
